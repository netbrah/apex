{
  "name": "apex-vscode-ide-companion",
  "displayName": "Apex Companion",
  "description": "Browse ~/.apex/ — settings, chat sessions, debug logs, and more.",
  "version": "1.0.0",
  "publisher": "netapp",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/QwenLM/qwen-code.git",
    "directory": "packages/vscode-ide-companion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "license": "LICENSE",
  "preview": true,
  "categories": [
    "Other"
  ],
  "keywords": [
    "apex",
    "ontap",
    "chat viewer",
    "session browser"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "apex-explorer",
          "title": "Apex",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "apex-explorer": [
        {
          "id": "apex.explorer",
          "name": "Apex"
        }
      ]
    },
    "commands": [
      {
        "command": "apex.openFile",
        "title": "Apex: Open File",
        "icon": "$(go-to-file)"
      },
      {
        "command": "apex.openSession",
        "title": "Apex: Open Chat Session",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "apex.refresh",
        "title": "Apex: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "apex.revealInFinder",
        "title": "Reveal in Finder",
        "icon": "$(folder-opened)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "apex.refresh",
          "when": "view == apex.explorer",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "apex.revealInFinder",
          "when": "view == apex.explorer && viewItem == folder",
          "group": "navigation"
        },
        {
          "command": "apex.revealInFinder",
          "when": "view == apex.explorer && viewItem == file",
          "group": "navigation"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "**/.apex/settings.json",
        "url": "./schemas/settings.schema.json"
      }
    ]
  },
  "main": "./dist/extension.cjs",
  "type": "module",
  "scripts": {
    "build": "npm run build:dev",
    "build:dev": "npm run check-types && node esbuild.js",
    "build:prod": "node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "watch": "node esbuild.js --watch",
    "package": "vsce package --no-dependencies",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.6.0",
    "esbuild": "^0.25.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {}
}

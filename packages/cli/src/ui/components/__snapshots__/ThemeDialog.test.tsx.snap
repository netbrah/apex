exports[`ThemeDialog Snapshots > should render correctly in theme selection mode 1`] = `
"╭──────────────────────────────────────────────────────────────────────────────────────────────────╮
│                                                                                                  │
│ > Select Theme                               Preview                                             │
│ ▲                                            ┌─────────────────────────────────────────────────┐ │
│ › 1. Apex Dark Dark                          │                                                 │ │
│   2. Apex Operator Dark                      │ 1 # function                                    │ │
│   3. ANSI Dark                               │ 2 def fibonacci(n):                             │ │
│   4. Default Dark                            │ 3     a, b = 0, 1                               │ │
│   5. ANSI Light Light                        │ 4     for _ in range(n):                        │ │
│ ▼                                            │ 5         a, b = b, a + b                       │ │
│                                              │ 6     return a                                  │ │
│                                              │                                                 │ │
│                                              │ 1 - print("Hello, " + name)                     │ │
│                                              │ 1 + print(f"Hello, {name}!")                    │ │
│                                              │                                                 │ │
│                                              └─────────────────────────────────────────────────┘ │
│                                                                                                  │
│ (Use Enter to select, Tab to configure scope)                                                    │
│                                                                                                  │
╰──────────────────────────────────────────────────────────────────────────────────────────────────╯"
`;

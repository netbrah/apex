{
  "security": {
    "auth": {
      "selectedType": "anthropic"
    }
  },
  "model": {
    "name": "claude-opus-4.6"
  },
  "theme": "Apex Dark",
  "lsp": {
    "enabled": true,
    "lspServers": {
      "cpp": {
        "command": "python3.11",
        "args": ["/u/palanisd/.apex/bin/ontap_lsp_bridge.py"],
        "extensionToLanguage": {
          ".cc": "cpp",
          ".h": "cpp",
          ".ut": "cpp"
        }
      }
    }
  },
  "context": {
    "fileName": ["APEX.md", "QWEN.md", "AGENTS.md"]
  },
  "ide": {
    "hasSeenNudge": true
  },
  "advanced": {
    "autoConfigureMemory": true
  },
  "mcpServers": {
    "reviewboard": {
      "command": "node",
      "args": ["$RB_INDEX"],
      "timeout": 30000,
      "trust": true,
      "env": {
        "REVIEWBOARD_BASE_URL": "https://reviewboard.netapp.com",
        "REVIEWBOARD_API_TOKEN": "$REVIEWBOARD_API_TOKEN"
      }
    },
    "cit": {
      "command": "$CIT_BIN",
      "timeout": 30000,
      "trust": true
    },
    "mastra-search": {
      "command": "$MASTRA_BIN",
      "args": [],
      "timeout": 30000,
      "trust": true,
      "excludeTools": [
        "search",
        "analyze_symbol_ast",
        "get_file",
        "file_search",
        "call_graph_fast",
        "trace_call_chain",
        "analyze_iterator",
        "generate_test_plan",
        "generate_unit_test",
        "smf_cli_mapping",
        "swagger_rest_mapping",
        "search_jira",
        "get_jira_issue",
        "get_confluence_page",
        "ask_reviewboard",
        "ask_confluence",
        "ask_jira",
        "analyze_defect",
        "ask_codeAnalyst",
        "agent_investigate"
      ],
      "env": {
        "OPENAI_API_KEY": "$OPENAI_API_KEY",
        "OPENAI_BASE_URL": "$OPENAI_BASE_URL",
        "NODE_EXTRA_CA_CERTS": "$NODE_EXTRA_CA_CERTS",
        "NODE_PATH": "$MASTRA_NODE_PATH",
        "JIRA_TOKEN": "$JIRA_TOKEN",
        "CONFLUENCE_TOKEN": "$CONFLUENCE_TOKEN",
        "REVIEWBOARD_API_TOKEN": "$REVIEWBOARD_API_TOKEN",
        "CONFLUENCE_USERNAME": "$CONFLUENCE_USERNAME"
      }
    }
  },
  "tools": {
    "truncateToolOutputThreshold": 200000,
    "truncateToolOutputLines": 5000
  },
